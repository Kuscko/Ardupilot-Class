# TECS - Conservative climb/descent
TECS_CLMB_MAX,3.0
TECS_SINK_MAX,2.0
TECS_TIME_CONST,6.0
TECS_SPDWEIGHT,1.0

# Airspeed - Safe range
ARSPD_FBW_MIN,12.0
ARSPD_FBW_MAX,20.0
TRIM_ARSPD_CM,1500

# Throttle - Limited
THR_MIN,0
THR_MAX,70
