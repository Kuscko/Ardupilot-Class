# Navigation - Gentle turns
LIM_ROLL_CD,3000
NAVL1_PERIOD,18
WP_LOITER_RAD,80

# Failsafes - Enabled
FS_SHORT_ACTN,1
FS_LONG_ACTN,2
BATT_LOW_VOLT,10.5
BATT_CRT_VOLT,10.0

# Fence - Enabled
FENCE_ENABLE,1
FENCE_RADIUS,500
FENCE_ALT_MAX,200
